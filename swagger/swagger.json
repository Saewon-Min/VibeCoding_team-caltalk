{
  "openapi": "3.0.3",
  "info": {
    "title": "Team CalTalk API",
    "version": "1.0.0",
    "description": "팀 단위 캘린더+채팅 협업 도구 Team CalTalk의 REST API 명세. `docs/1-domain-definition.md`(ENT-01~07, BR-01~16), `docs/4-database-erd.md`, `docs/6-project-structure.md`, `docs/7-execution-plan.md`(BE-xx/SC-xx)를 근거 문서로 한다.\n인증 방식(JWT 등)은 PRD 9장 기준 미확정이며 본 문서는 Bearer 토큰 스킴으로 모델링한다."
  },
  "servers": [
    {
      "url": "/",
      "description": "API 서버 (base URL은 배포 환경에 따라 다름)"
    }
  ],
  "tags": [
    { "name": "health", "description": "헬스체크 (BE-01)" },
    { "name": "auth", "description": "인증 모듈 (BR-01, BE-06/07)" },
    { "name": "team-schedule", "description": "팀·일정 관리 모듈 (BR-02,03,07~09,14~16, BE-08~14)" },
    { "name": "chat", "description": "채팅 모듈 (BR-06, BE-16/17)" },
    { "name": "change-request", "description": "일정 변경 요청 처리 모듈 (BR-04,05,10~13, BE-18~22)" }
  ],
  "security": [
    { "bearerAuth": [] }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["health"],
        "summary": "서버 헬스체크",
        "description": "BE-01. 서버 기동 및 기본 상태 확인용 엔드포인트. 인증 불필요.",
        "security": [],
        "responses": {
          "200": {
            "description": "정상 동작 중",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthStatus" }
              }
            }
          }
        }
      }
    },
    "/api/auth/signup": {
      "post": {
        "tags": ["auth"],
        "summary": "회원가입",
        "description": "BE-06 / BR-01 / SC-01. 이름/이메일/비밀번호로 신규 사용자를 등록한다. 비밀번호는 해시로만 저장되며 응답에는 절대 포함되지 않는다.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SignupRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "회원가입 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["auth"],
        "summary": "로그인",
        "description": "BE-07 / BR-01 / SC-01(E1). 이메일/비밀번호로 로그인하여 인증 토큰을 발급받는다. 잘못된 비밀번호와 미존재 이메일 모두 401로 응답하며 어느 쪽인지 노출하지 않는다.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "로그인 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LoginResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/teams": {
      "post": {
        "tags": ["team-schedule"],
        "summary": "팀 생성",
        "description": "BE-08 / BR-15 / SC-02. 팀을 생성하며, 생성자는 트랜잭션 내에서 자동으로 해당 팀의 팀장(role=leader)으로 등록된다.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateTeamRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "팀 생성 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TeamWithRole" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "get": {
        "tags": ["team-schedule"],
        "summary": "내 소속 팀 목록 조회",
        "description": "BE-08(§1.2 편입 항목). 로그인한 사용자가 소속된 모든 팀과 각 팀에서의 역할을 반환한다. FE-08/FE-10(TeamListPage)의 전제 조건 API.",
        "responses": {
          "200": {
            "description": "소속 팀 목록",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/TeamWithRole" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/teams/{teamId}/members/search": {
      "get": {
        "tags": ["team-schedule"],
        "summary": "이메일로 가입된 사용자 검색 (팀원 추가용)",
        "description": "BE-09 / BR-14 / SC-02. 팀장이 팀에 추가할 대상을 이메일 정확 일치로 검색한다. 초대/수락 절차 없이 검색 결과를 그대로 팀원 추가 API에 사용한다. 팀장만 호출 가능.",
        "parameters": [
          { "$ref": "#/components/parameters/teamId" },
          {
            "name": "email",
            "in": "query",
            "required": true,
            "description": "검색할 사용자의 이메일(정확 일치)",
            "schema": { "type": "string", "format": "email" }
          }
        ],
        "responses": {
          "200": {
            "description": "검색된 사용자",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserSummary" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": {
            "description": "가입된 사용자를 찾을 수 없습니다 (BR-14, SC-02 E2)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/teams/{teamId}/members": {
      "get": {
        "tags": ["team-schedule"],
        "summary": "팀원 목록 조회",
        "description": "BE-09. 팀 소속 멤버와 각 멤버의 역할을 조회한다. 팀 소속 사용자만 호출 가능(BR-16).",
        "parameters": [
          { "$ref": "#/components/parameters/teamId" }
        ],
        "responses": {
          "200": {
            "description": "팀원 목록",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/TeamMember" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "post": {
        "tags": ["team-schedule"],
        "summary": "팀원 즉시 추가",
        "description": "BE-09 / BR-14 / SC-02. 이메일 검색(`GET /members/search`) 결과의 userId로 팀원을 즉시 추가한다(초대 발송/수락 대기 없음). role은 항상 member로 생성되며, 팀장만 호출 가능.",
        "parameters": [
          { "$ref": "#/components/parameters/teamId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddMemberRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "팀원 추가 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TeamMember" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "409": {
            "description": "이미 팀에 소속된 사용자입니다",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/teams/{teamId}/members/{userId}": {
      "patch": {
        "tags": ["team-schedule"],
        "summary": "팀원 역할 변경",
        "description": "BE-10 / BR-09 / SC-11. 팀원의 역할을 변경한다. 변경 결과 해당 팀의 팀장이 0명이 되는 경우 허용되지 않는다. 팀장만 호출 가능.",
        "parameters": [
          { "$ref": "#/components/parameters/teamId" },
          { "$ref": "#/components/parameters/userId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateMemberRoleRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "역할 변경 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TeamMember" }
              }
            }
          },
          "400": {
            "description": "팀에는 최소 1명의 팀장이 있어야 합니다 (BR-09, SC-11)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": {
            "description": "팀에는 최소 1명의 팀장이 있어야 합니다 (BR-09, SC-11)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["team-schedule"],
        "summary": "팀원 제외",
        "description": "BE-10 / BR-09 / SC-11. 팀원을 팀에서 제외한다. 제외 결과 해당 팀의 팀장이 0명이 되는 경우 허용되지 않는다. 팀장만 호출 가능.",
        "parameters": [
          { "$ref": "#/components/parameters/teamId" },
          { "$ref": "#/components/parameters/userId" }
        ],
        "responses": {
          "204": { "description": "제외 성공" },
          "400": {
            "description": "팀에는 최소 1명의 팀장이 있어야 합니다 (BR-09, SC-11)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": {
            "description": "팀에는 최소 1명의 팀장이 있어야 합니다 (BR-09, SC-11)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/teams/{teamId}/schedules": {
      "post": {
        "tags": ["team-schedule"],
        "summary": "팀 일정 생성",
        "description": "BE-12 / BR-02 / BR-07 / SC-03. 팀장이 제목/일시/참여자를 지정해 일정을 생성한다. Schedule과 ScheduleParticipant가 하나의 트랜잭션으로 생성된다. 팀원 호출 시 403.",
        "parameters": [
          { "$ref": "#/components/parameters/teamId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateScheduleRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "일정 생성 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ScheduleDetail" }
              }
            }
          },
          "400": {
            "description": "잘못된 요청(참여자가 팀 소속이 아님, endAt<=startAt 등)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "get": {
        "tags": ["team-schedule"],
        "summary": "팀 일정 월/주/일 조회",
        "description": "BE-14 / BR-03 / BR-16 / SC-04. view(month|week|day)와 기준 date로 일정 목록을 조회한다. 각 항목은 호출자가 팀장일 때만 true인 canEdit 필드를 포함한다(BR-03).",
        "parameters": [
          { "$ref": "#/components/parameters/teamId" },
          {
            "name": "view",
            "in": "query",
            "required": true,
            "description": "조회 범위 단위",
            "schema": { "type": "string", "enum": ["month", "week", "day"] }
          },
          {
            "name": "date",
            "in": "query",
            "required": true,
            "description": "기준 일자",
            "schema": { "type": "string", "format": "date", "example": "2026-07-10" }
          }
        ],
        "responses": {
          "200": {
            "description": "일정 목록",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/ScheduleListItem" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/teams/{teamId}/schedules/{scheduleId}": {
      "get": {
        "tags": ["team-schedule"],
        "summary": "팀 일정 상세 조회",
        "description": "SC-04. 특정 일정의 상세 정보(참여자 포함)를 조회한다. 팀 소속 사용자만 호출 가능(BR-16).",
        "parameters": [
          { "$ref": "#/components/parameters/teamId" },
          { "$ref": "#/components/parameters/scheduleId" }
        ],
        "responses": {
          "200": {
            "description": "일정 상세",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ScheduleDetail" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "patch": {
        "tags": ["team-schedule"],
        "summary": "팀 일정 수정",
        "description": "BE-13 / BR-02 / BR-03 / SC-05. 일정 필드를 수정한다. 팀장만 호출 가능하며 팀원 호출 시 403.",
        "parameters": [
          { "$ref": "#/components/parameters/teamId" },
          { "$ref": "#/components/parameters/scheduleId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateScheduleRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "수정 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ScheduleDetail" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["team-schedule"],
        "summary": "팀 일정 삭제",
        "description": "BE-13 / BR-02 / BR-03 / SC-05. 일정을 삭제하고 연결된 ScheduleParticipant 레코드도 함께 삭제(cascade)한다. 팀장만 호출 가능.",
        "parameters": [
          { "$ref": "#/components/parameters/teamId" },
          { "$ref": "#/components/parameters/scheduleId" }
        ],
        "responses": {
          "204": { "description": "삭제 성공" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/teams/{teamId}/messages": {
      "post": {
        "tags": ["chat"],
        "summary": "채팅 메시지 작성",
        "description": "BE-16 / BR-01 / BR-06 / SC-12. 팀 채팅에 일반 메시지를 작성한다. 이 엔드포인트로 생성되는 메시지의 messageType은 항상 general이다. change_request 유형 메시지는 change-request 모듈의 변경 요청 제기 API를 통해서만, system 유형 메시지는 서버가 내부적으로만 생성하며 둘 다 클라이언트가 직접 생성할 수 없다. BR-06(메시지 불변성)에 따라 메시지 수정/삭제 엔드포인트는 API 전체에 존재하지 않는다.",
        "parameters": [
          { "$ref": "#/components/parameters/teamId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateMessageRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "메시지 작성 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "400": {
            "description": "본문이 비어 있음",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "get": {
        "tags": ["chat"],
        "summary": "일자별 채팅 이력 조회",
        "description": "BE-17 / BR-06 / BR-16 / SC-12. date 기준 일자별 채팅 이력을 작성일시(createdAt) 순으로 반환한다. since를 함께 전달하면 해당 시각 이후의 신규 메시지만 반환하며, WebSocket 미도입에 따른 폴링 방식을 지원하기 위한 파라미터다(PRD 9장). 과거 일자 조회도 동일하게 동작한다.",
        "parameters": [
          { "$ref": "#/components/parameters/teamId" },
          {
            "name": "date",
            "in": "query",
            "required": true,
            "description": "조회할 일자",
            "schema": { "type": "string", "format": "date", "example": "2026-07-10" }
          },
          {
            "name": "since",
            "in": "query",
            "required": false,
            "description": "이 시각 이후 작성된 메시지만 반환(폴링용)",
            "schema": { "type": "string", "format": "date-time" }
          }
        ],
        "responses": {
          "200": {
            "description": "메시지 목록(작성일시 오름차순)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Message" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/teams/{teamId}/schedules/{scheduleId}/change-requests": {
      "post": {
        "tags": ["change-request"],
        "summary": "일정 변경 요청 제기",
        "description": "BE-18 / BR-04 / BR-10 / SC-06. 자신이 참여자로 지정된 일정에 한해 변경 요청을 제기한다. ScheduleChangeRequest(status=pending)와 연결된 Message(messageType=change_request)가 하나의 트랜잭션으로 생성된다. 참여자가 아닌 팀원이 요청 시 403(또는 400).",
        "parameters": [
          { "$ref": "#/components/parameters/teamId" },
          { "$ref": "#/components/parameters/scheduleId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateChangeRequestRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "변경 요청 제기 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ScheduleChangeRequest" }
              }
            }
          },
          "400": {
            "description": "요청자가 해당 일정의 참여자가 아님(BR-10, SC-06 E1) 등 잘못된 요청",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": {
            "description": "요청자가 해당 일정의 참여자가 아님(BR-10, SC-06 E1) 또는 팀 비소속",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/teams/{teamId}/change-requests": {
      "get": {
        "tags": ["change-request"],
        "summary": "일정 변경 요청 목록 조회",
        "description": "BE-19. scheduleId, status로 필터링 가능한 변경 요청 목록을 조회한다. 팀 소속 사용자만 호출 가능(BR-16).",
        "parameters": [
          { "$ref": "#/components/parameters/teamId" },
          {
            "name": "scheduleId",
            "in": "query",
            "required": false,
            "description": "특정 일정으로 필터링",
            "schema": { "type": "integer", "format": "int64" }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "description": "상태로 필터링",
            "schema": { "$ref": "#/components/schemas/ChangeRequestStatus" }
          }
        ],
        "responses": {
          "200": {
            "description": "변경 요청 목록",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/ScheduleChangeRequest" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/teams/{teamId}/change-requests/{requestId}": {
      "get": {
        "tags": ["change-request"],
        "summary": "일정 변경 요청 상세 조회",
        "description": "BE-19. 변경 요청 1건의 상세 정보를 조회한다. 팀 소속 사용자만 호출 가능(BR-16).",
        "parameters": [
          { "$ref": "#/components/parameters/teamId" },
          { "$ref": "#/components/parameters/requestId" }
        ],
        "responses": {
          "200": {
            "description": "변경 요청 상세",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ScheduleChangeRequest" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/teams/{teamId}/change-requests/{requestId}/approve": {
      "patch": {
        "tags": ["change-request"],
        "summary": "일정 변경 요청 승인",
        "description": "BE-20 / BR-05 / BR-11 / BR-13 / SC-07 / SC-09. 팀장이 승인하면 요청 상태가 approved로 전환되고 제안 값이 Schedule에 반영된다. 동일 Schedule의 나머지 대기(pending) 요청은 모두 rejected로 자동 전환되며(BR-11), 승인/자동거절 각각에 대해 시스템 메시지가 생성된다(BR-13). 전체가 단일 트랜잭션으로 원자적 처리된다. 팀원 호출 시 403, 이미 처리된 요청 재처리 시 409.",
        "parameters": [
          { "$ref": "#/components/parameters/teamId" },
          { "$ref": "#/components/parameters/requestId" }
        ],
        "responses": {
          "200": {
            "description": "승인 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ScheduleChangeRequest" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": {
            "description": "이미 처리된(대기 상태가 아닌) 요청입니다(SC-07 E2, SC-09 E1)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/teams/{teamId}/change-requests/{requestId}/reject": {
      "patch": {
        "tags": ["change-request"],
        "summary": "일정 변경 요청 거절",
        "description": "BE-21 / BR-05 / BR-13 / SC-08. 팀장이 거절하면 상태가 rejected로 전환되며 Schedule은 변경되지 않는다. 거절 결과에 대한 시스템 메시지가 생성된다(BR-13). 팀원(또는 타 팀 팀장) 호출 시 403, 이미 처리된 요청 재처리 시 409.",
        "parameters": [
          { "$ref": "#/components/parameters/teamId" },
          { "$ref": "#/components/parameters/requestId" }
        ],
        "responses": {
          "200": {
            "description": "거절 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ScheduleChangeRequest" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": {
            "description": "이미 처리된 요청입니다",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/teams/{teamId}/change-requests/{requestId}/cancel": {
      "patch": {
        "tags": ["change-request"],
        "summary": "일정 변경 요청 취소",
        "description": "BE-22 / BR-12 / SC-10. 요청자 본인이 대기(pending) 상태인 자신의 요청만 취소할 수 있다. 취소 시 상태가 cancelled로 전환되고 시스템 메시지가 생성되며 팀장의 처리 대상에서 제외된다. 본인이 아닌 사용자가 취소 시도 시 403(SC-10 E2), 이미 처리된 요청 취소 시도 시 409(SC-10 E1).",
        "parameters": [
          { "$ref": "#/components/parameters/teamId" },
          { "$ref": "#/components/parameters/requestId" }
        ],
        "responses": {
          "200": {
            "description": "취소 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ScheduleChangeRequest" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": {
            "description": "요청자 본인이 아님(SC-10 E2)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": {
            "description": "이미 처리된(대기 상태가 아닌) 요청입니다(SC-10 E1)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "BR-01. 회원가입/로그인/헬스체크를 제외한 모든 API에 필요. 토큰이 없거나 유효하지 않으면 401을 반환하며 어떠한 팀/일정/채팅 데이터도 포함하지 않는다(SC-01 E2)."
      }
    },
    "parameters": {
      "teamId": {
        "name": "teamId",
        "in": "path",
        "required": true,
        "description": "팀 ID",
        "schema": { "type": "integer", "format": "int64" }
      },
      "userId": {
        "name": "userId",
        "in": "path",
        "required": true,
        "description": "사용자 ID",
        "schema": { "type": "integer", "format": "int64" }
      },
      "scheduleId": {
        "name": "scheduleId",
        "in": "path",
        "required": true,
        "description": "일정 ID",
        "schema": { "type": "integer", "format": "int64" }
      },
      "requestId": {
        "name": "requestId",
        "in": "path",
        "required": true,
        "description": "일정 변경 요청 ID",
        "schema": { "type": "integer", "format": "int64" }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "잘못된 요청",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Unauthorized": {
        "description": "인증 실패(토큰 없음/무효/만료). 데이터 미포함(BR-01)",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Forbidden": {
        "description": "권한 없음(역할 부족 또는 팀 비소속, BR-16)",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "NotFound": {
        "description": "리소스를 찾을 수 없음",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Conflict": {
        "description": "상태 충돌(중복 생성, 잘못된 상태 전이 등)",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "description": "모든 4xx/5xx 응답에 공통으로 사용되는 에러 바디 형식",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "기계 판독용 에러 코드",
                "example": "FORBIDDEN"
              },
              "message": {
                "type": "string",
                "description": "사용자에게 노출 가능한 에러 메시지",
                "example": "팀에는 최소 1명의 팀장이 있어야 합니다"
              }
            },
            "required": ["code", "message"]
          }
        },
        "required": ["error"]
      },
      "HealthStatus": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "ok" }
        },
        "required": ["status"]
      },
      "Role": {
        "type": "string",
        "description": "ENT-03 TeamMembership.role",
        "enum": ["leader", "member"]
      },
      "MessageType": {
        "type": "string",
        "description": "ENT-06 Message.messageType. general=일반 대화, change_request=변경 요청 메시지(클라이언트가 change-request API를 통해서만 간접 생성), system=서버가 자동 생성하는 처리 결과 메시지(클라이언트가 직접 생성 불가)",
        "enum": ["general", "change_request", "system"]
      },
      "ChangeRequestStatus": {
        "type": "string",
        "description": "ENT-07 ScheduleChangeRequest.status",
        "enum": ["pending", "approved", "rejected", "cancelled"]
      },
      "User": {
        "type": "object",
        "description": "ENT-01 User. password/passwordHash는 응답에 절대 포함되지 않는다.",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "name", "email", "createdAt"]
      },
      "UserSummary": {
        "type": "object",
        "description": "이메일 검색 결과 등에 사용되는 최소 사용자 정보",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" }
        },
        "required": ["id", "name", "email"]
      },
      "SignupRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "format": "password", "minLength": 8 }
        },
        "required": ["name", "email", "password"]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "format": "password" }
        },
        "required": ["email", "password"]
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string", "description": "인증 토큰(구체적 형식은 백엔드 구현에 따름, PRD 9장 미확정)" },
          "user": { "$ref": "#/components/schemas/UserSummary" }
        },
        "required": ["token", "user"]
      },
      "Team": {
        "type": "object",
        "description": "ENT-02 Team",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "name": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "name", "createdAt", "updatedAt"]
      },
      "TeamWithRole": {
        "description": "GET /api/teams, POST /api/teams 응답에서 사용. 호출자의 해당 팀 내 역할(role)을 포함한다.",
        "allOf": [
          { "$ref": "#/components/schemas/Team" },
          {
            "type": "object",
            "properties": {
              "role": { "$ref": "#/components/schemas/Role" }
            },
            "required": ["role"]
          }
        ]
      },
      "CreateTeamRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" }
        },
        "required": ["name"]
      },
      "TeamMember": {
        "type": "object",
        "description": "ENT-03 TeamMembership을 사용자 정보와 함께 표현한 뷰",
        "properties": {
          "userId": { "type": "integer", "format": "int64" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "role": { "$ref": "#/components/schemas/Role" },
          "joinedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["userId", "name", "email", "role", "joinedAt"]
      },
      "AddMemberRequest": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer",
            "format": "int64",
            "description": "이메일 검색(GET /members/search) 결과로 얻은 사용자 ID"
          }
        },
        "required": ["userId"]
      },
      "UpdateMemberRoleRequest": {
        "type": "object",
        "properties": {
          "role": { "$ref": "#/components/schemas/Role" }
        },
        "required": ["role"]
      },
      "Schedule": {
        "type": "object",
        "description": "ENT-04 Schedule",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "teamId": { "type": "integer", "format": "int64" },
          "title": { "type": "string" },
          "description": { "type": "string", "nullable": true },
          "startAt": { "type": "string", "format": "date-time" },
          "endAt": { "type": "string", "format": "date-time" },
          "createdBy": {
            "type": "integer",
            "format": "int64",
            "description": "작성자(팀장) 사용자 ID"
          },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "teamId", "title", "startAt", "endAt", "createdBy", "createdAt", "updatedAt"]
      },
      "ScheduleListItem": {
        "description": "BE-14. 목록 조회 시 각 일정에 canEdit(호출자가 팀장일 때만 true, BR-03)이 포함된다.",
        "allOf": [
          { "$ref": "#/components/schemas/Schedule" },
          {
            "type": "object",
            "properties": {
              "canEdit": { "type": "boolean" }
            },
            "required": ["canEdit"]
          }
        ]
      },
      "ParticipantSummary": {
        "type": "object",
        "description": "ENT-05 ScheduleParticipant를 사용자 정보와 함께 표현한 뷰",
        "properties": {
          "userId": { "type": "integer", "format": "int64" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" }
        },
        "required": ["userId", "name", "email"]
      },
      "ScheduleDetail": {
        "description": "일정 생성/상세 조회/수정 응답에서 사용. 참여자 목록을 포함한다.",
        "allOf": [
          { "$ref": "#/components/schemas/Schedule" },
          {
            "type": "object",
            "properties": {
              "participants": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/ParticipantSummary" }
              }
            },
            "required": ["participants"]
          }
        ]
      },
      "CreateScheduleRequest": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string", "nullable": true },
          "startAt": { "type": "string", "format": "date-time" },
          "endAt": {
            "type": "string",
            "format": "date-time",
            "description": "startAt보다 이후여야 한다"
          },
          "participantUserIds": {
            "type": "array",
            "items": { "type": "integer", "format": "int64" },
            "description": "참여자로 지정할 팀 소속 사용자 ID 목록. 팀 비소속 사용자가 포함되면 400."
          }
        },
        "required": ["title", "startAt", "endAt"]
      },
      "UpdateScheduleRequest": {
        "type": "object",
        "description": "제공된 필드만 갱신한다(부분 수정)",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string", "nullable": true },
          "startAt": { "type": "string", "format": "date-time" },
          "endAt": { "type": "string", "format": "date-time" },
          "participantUserIds": {
            "type": "array",
            "items": { "type": "integer", "format": "int64" }
          }
        }
      },
      "Message": {
        "type": "object",
        "description": "ENT-06 Message. authorId는 system 유형 메시지의 경우 nullable(BR-13).",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "teamId": { "type": "integer", "format": "int64" },
          "authorId": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "description": "작성자 사용자 ID. 시스템이 자동 생성한 메시지(messageType=system)는 null"
          },
          "messageType": { "$ref": "#/components/schemas/MessageType" },
          "content": { "type": "string" },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "작성일시. 일자 단위 이력 그룹핑의 기준(BR-06)"
          }
        },
        "required": ["id", "teamId", "authorId", "messageType", "content", "createdAt"]
      },
      "CreateMessageRequest": {
        "type": "object",
        "properties": {
          "content": { "type": "string", "minLength": 1 }
        },
