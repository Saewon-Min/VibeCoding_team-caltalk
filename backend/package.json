{
  "name": "team-caltalk-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Team CalTalk REST API (Node.js + Express + PostgreSQL)",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate": "node-pg-migrate up -m src/db/migrations",
    "migrate:undo": "node-pg-migrate down -m src/db/migrations",
    "seed": "node scripts/seed.js",
    "test": "jest",
    "lint": "eslint src tests scripts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-pg-migrate": "^7.6.1",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3"
  }
}
